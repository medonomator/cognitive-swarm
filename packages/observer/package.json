{
  "name": "@cognitive-swarm/observer",
  "version": "0.1.0",
  "description": "Observe Claude Code conversations, analyze with swarm, report to Telegram",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "observe": "tsx src/run.ts",
    "observe:dry": "tsx src/run.ts --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cognitive-swarm/core": "*",
    "@cognitive-swarm/signals": "*",
    "@cognitive-swarm/agent": "*",
    "@cognitive-swarm/consensus": "*",
    "@cognitive-swarm/orchestrator": "*",
    "@cognitive-swarm/memory-qdrant": "*",
    "@cognitive-engine/core": "*",
    "openai": "^4"
  },
  "devDependencies": {
    "tsx": "^4"
  },
  "license": "Apache-2.0",
  "author": "Dmitry Zorin"
}
